# 复制此文件为 .env 并填入真实值
# cp .env.example .env

# LLM 配置
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
LLM_MODEL=mimo-v2.5-pro

# 服务配置
APP_HOST=0.0.0.0
APP_PORT=8000

# 钉钉机器人（Stream 模式，可选）
DINGTALK_CLIENT_ID=your-dingtalk-client-id
DINGTALK_CLIENT_SECRET=your-dingtalk-client-secret
